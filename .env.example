# ==========================================
# CLIENT (FRONTEND) CONFIGURATION
# ==========================================
# Vite dev server proxy target can also be specified if needed,
# but normally in production, dynamic relative routes are used.
VITE_API_URL=

# ==========================================
# SERVER (BACKEND) CONFIGURATION
# ==========================================
PORT=5001
NODE_ENV=production

# URLs for CORS and Redirect callbacks
# For Vercel deployments, if same-origin is used, these can be omitted or set to the deployment URL.
CLIENT_URL=https://your-app-name.vercel.app
SERVER_URL=https://your-app-name.vercel.app
FRONTEND_URL=https://your-app-name.vercel.app

# Database
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ai_mock_interview?retryWrites=true&w=majority

# Authentication
JWT_SECRET=your_minimum_32_character_jwt_secret_here
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Gemini AI API Key (required for interview mock evaluation and question generation)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Social Auth integrations (optional)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# Firebase Admin SDK (optional, if using push/auth)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Logging level
LOG_LEVEL=info
